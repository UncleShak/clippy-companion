{
  "name": "clippy-companion",
  "displayName": "Clippy Companion",
  "description": "Your retro coding buddy who reacts to errors",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "clippy-sidebar",
          "title": "Clippy",
          "icon": "media/clippy-icon.svg"
        }
      ]
    },
    "views": {
      "clippy-sidebar": [
        {
          "type": "webview",
          "id": "clippyView",
          "name": "Clippy Companion"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
