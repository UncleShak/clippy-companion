{
  "name": "clippy-companion",
  "displayName": "Clippy Companion",
  "description": "Your retro coding buddy who reacts to errors",
  "version": "0.0.1",
  "publisher": "undefined_publisher",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "type": "webview",
          "id": "clippyView",
          "name": "Clippy Companion"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@types/mocha": "^10.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "clippyjs": "^0.0.3"
  }
}